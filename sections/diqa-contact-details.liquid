{{ 'diqa-pro-pages.css' | asset_url | stylesheet_tag }}

<section class="diqa-pro-stack">
  <div class="page-width">
    <div class="diqa-pro-grid">
      <article class="diqa-pro-card">
        <h3>{{ section.settings.card_one_title }}</h3>
        <p>{{ section.settings.card_one_text }}</p>
      </article>
      <article class="diqa-pro-card">
        <h3>{{ section.settings.card_two_title }}</h3>
        <p>{{ section.settings.card_two_text }}</p>
      </article>
      <article class="diqa-pro-card">
        <h3>{{ section.settings.card_three_title }}</h3>
        <p>{{ section.settings.card_three_text }}</p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MarOumayra Contact Details",
  "settings": [
    { "type": "text", "id": "card_one_title", "label": "Card 1 title", "default": "Customer Care" },
    { "type": "textarea", "id": "card_one_text", "label": "Card 1 text", "default": "Email: support@diqa.com\nResponse time: within 24h." },
    { "type": "text", "id": "card_two_title", "label": "Card 2 title", "default": "Business Inquiries" },
    { "type": "textarea", "id": "card_two_text", "label": "Card 2 text", "default": "For wholesale and collaborations: business@diqa.com." },
    { "type": "text", "id": "card_three_title", "label": "Card 3 title", "default": "Office Hours" },
    { "type": "textarea", "id": "card_three_text", "label": "Card 3 text", "default": "Monday - Friday\n09:00 - 18:00 CET." }
  ],
  "presets": [{ "name": "MarOumayra Contact Details" }]
}
{% endschema %}
