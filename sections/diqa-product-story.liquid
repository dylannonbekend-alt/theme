{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ product.title }}</h2>
      <p class="diqa-copy">
        {{ section.settings.intro }}
      </p>

      <div class="diqa-grid-3">
        <article class="diqa-pill">
          <h3>{{ section.settings.point_one_title }}</h3>
          <p>{{ section.settings.point_one_text }}</p>
        </article>
        <article class="diqa-pill">
          <h3>{{ section.settings.point_two_title }}</h3>
          <p>{{ section.settings.point_two_text }}</p>
        </article>
        <article class="diqa-pill">
          <h3>{{ section.settings.point_three_title }}</h3>
          <p>{{ section.settings.point_three_text }}</p>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MAROUMAYRA Product Story",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Productinformatie"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Een sterke basis voor een moderne, bescheiden garderobe. Gemaakt van kwaliteitsstof met een comfortabele valling."
    },
    {
      "type": "text",
      "id": "point_one_title",
      "label": "Point 1 title",
      "default": "Waarom dit product"
    },
    {
      "type": "textarea",
      "id": "point_one_text",
      "label": "Point 1 text",
      "default": "Kwaliteitsstof, ademend comfort en een verzorgde afwerking."
    },
    {
      "type": "text",
      "id": "point_two_title",
      "label": "Point 2 title",
      "default": "Pasvorm en draaggevoel"
    },
    {
      "type": "textarea",
      "id": "point_two_text",
      "label": "Point 2 text",
      "default": "Gebalanceerd silhouet dat prettig draagt en de hele dag netjes blijft."
    },
    {
      "type": "text",
      "id": "point_three_title",
      "label": "Point 3 title",
      "default": "Onderhoud"
    },
    {
      "type": "textarea",
      "id": "point_three_text",
      "label": "Point 3 text",
      "default": "Behandel met zorg om kwaliteit en afwerking te behouden. Bekijk de pagina Stofverzorging voor volledige instructies."
    }
  ],
  "presets": [
    {
      "name": "MAROUMAYRA Product Story"
    }
  ]
}
{% endschema %}
