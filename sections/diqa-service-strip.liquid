{{ 'diqa-pro-storefront.css' | asset_url | stylesheet_tag }}

<section class="diqa-service-strip">
  <div class="page-width">
    <div class="diqa-service-strip__wrap">
      {% for block in section.blocks %}
        <article class="diqa-service-strip__item" {{ block.shopify_attributes }}>
          <p class="diqa-service-strip__title">{{ block.settings.title }}</p>
          <p class="diqa-service-strip__text">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MarOumayra Service Strip",
  "blocks": [
    {
      "type": "service",
      "name": "Service-item",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Snelle verzending" },
        { "type": "text", "id": "text", "label": "Tekst", "default": "Verzonden binnen 1-2 werkdagen." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "MarOumayra Service Strip",
      "blocks": [
        { "type": "service", "settings": { "title": "Snelle verzending", "text": "Verzonden binnen 1-2 werkdagen." } },
        { "type": "service", "settings": { "title": "Eenvoudig retourneren", "text": "14 dagen retour en omruilen." } },
        { "type": "service", "settings": { "title": "Veilig afrekenen", "text": "Beveiligde en betrouwbare betaalomgeving." } },
        { "type": "service", "settings": { "title": "Kwaliteit", "text": "Zorgvuldig geselecteerde stoffen en afwerking." } }
      ]
    }
  ]
}
{% endschema %}
