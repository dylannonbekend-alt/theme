{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ section.settings.heading }}</h2>
      <p class="diqa-copy">{{ section.settings.copy }}</p>

      <div class="diqa-grid-3" style="grid-template-columns: 1fr;">
        {% for block in section.blocks %}
          <details class="diqa-pill" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <p style="margin-top: 0.7rem;">{{ block.settings.answer }}</p>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MAROUMAYRA FAQ Luxury",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Text",
      "default": "Need help? Here are the most common questions around shipping, returns, and care."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is the delivery time?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Orders are processed quickly and usually delivered within 1-3 business days in the EU."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "MAROUMAYRA FAQ Luxury"
    }
  ]
}
{% endschema %}
