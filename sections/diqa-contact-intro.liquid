{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ section.settings.heading }}</h2>
      <p class="diqa-copy">{{ section.settings.copy }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DIQA Contact Intro",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We are here to assist you" },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Text",
      "default": "For orders, partnerships or product questions, reach out and our team will respond quickly."
    }
  ],
  "presets": [
    {
      "name": "DIQA Contact Intro"
    }
  ]
}
{% endschema %}
