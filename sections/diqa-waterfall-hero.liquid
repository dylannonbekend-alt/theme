{{ 'diqa-waterfall-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'diqa-waterfall-hero.js' | asset_url }}" defer></script>

<section
  class="diqa-waterfall"
  data-diqa-waterfall
  style="
    --diqa-waterfall-start: {{ section.settings.bg_start }};
    --diqa-waterfall-end: {{ section.settings.bg_end }};
    --diqa-waterfall-accent: {{ section.settings.accent }};
    --diqa-waterfall-text: {{ section.settings.text_color }};
  "
>
  <canvas class="diqa-waterfall__canvas" aria-hidden="true"></canvas>
  <div class="diqa-waterfall__veil" aria-hidden="true"></div>

  <div class="diqa-waterfall__inner page-width">
    <div class="diqa-waterfall__left">
      <div class="diqa-waterfall__content">
        <p class="diqa-waterfall__kicker">{{ section.settings.kicker | default: 'DIQA Collectie' }}</p>
        <h1 class="diqa-waterfall__title">{{ section.settings.title | default: 'Stijl in beweging, rust in uitstraling.' }}</h1>
        <p class="diqa-waterfall__copy">{{ section.settings.copy | default: 'Een heldere visuele stijl met warme tinten en een moderne, verzorgde uitstraling.' }}</p>
        <div class="diqa-waterfall__actions">
          {% assign primary_href = section.settings.primary_link | default: routes.collections_url %}
          {% assign secondary_href = section.settings.secondary_link | default: '' %}

          <a class="button button-primary" href="{{ primary_href }}">
            {{ section.settings.primary_label | default: 'Bekijk collectie' }}
          </a>

          {% if secondary_href != blank and secondary_href != primary_href %}
            <a class="button button-secondary" href="{{ secondary_href }}">
              {{ section.settings.secondary_label | default: 'Over DIQA' }}
            </a>
          {% endif %}
        </div>

      </div>

      <div class="diqa-waterfall__micro">
        <span>Warme zandtinten</span>
        <span>Comfortabele valling</span>
        <span>Zakelijke premium stijl</span>
      </div>
    </div>

    <div class="diqa-waterfall__stage-wrap" data-waterfall-tilt>
      <div class="diqa-waterfall__orb diqa-waterfall__orb--one" aria-hidden="true"></div>
      <div class="diqa-waterfall__orb diqa-waterfall__orb--two" aria-hidden="true"></div>
      <div class="diqa-waterfall__orb diqa-waterfall__orb--three" aria-hidden="true"></div>

      <div class="diqa-waterfall__stage">
        <article class="diqa-waterfall__panel">
          <p class="diqa-waterfall__panel-kicker">{{ section.settings.panel_kicker }}</p>
          <p class="diqa-waterfall__panel-text">{{ section.settings.panel_text }}</p>

          <div class="diqa-waterfall__topic-tabs">
            <a
              class="diqa-waterfall__topic-tab is-active"
              href="{{ section.settings.topic_one_link | default: routes.collections_url }}"
            >
              {{ section.settings.topic_one_label }}
            </a>
            <a
              class="diqa-waterfall__topic-tab"
              href="{{ section.settings.topic_two_link | default: routes.collections_url }}"
            >
              {{ section.settings.topic_two_label }}
            </a>
            <a
              class="diqa-waterfall__topic-tab"
              href="{{ section.settings.topic_three_link | default: routes.collections_url }}"
            >
              {{ section.settings.topic_three_label }}
            </a>
          </div>

          <div class="diqa-waterfall__topic-content">
            <p class="diqa-waterfall__topic-title">{{ section.settings.topic_one_label }}</p>
            <p class="diqa-waterfall__topic-copy">{{ section.settings.topic_one_text }}</p>
            <a
              class="diqa-waterfall__topic-link"
              href="{{ section.settings.topic_one_link | default: routes.collections_url }}"
            >
              {{ section.settings.topic_cta_label }}
            </a>
          </div>
          <span class="diqa-waterfall__panel-line" aria-hidden="true"></span>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DIQA Waterfall Hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "DIQA Collectie" },
    { "type": "text", "id": "title", "label": "Title", "default": "Stijl in beweging, rust in uitstraling." },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Een heldere visuele stijl met warme tinten en een moderne, verzorgde uitstraling."
    },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Bekijk collectie" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Over DIQA" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "panel_kicker", "label": "Panel kicker", "default": "DIQA Signature" },
    { "type": "textarea", "id": "panel_text", "label": "Panel text", "default": "Kwaliteitsstoffen, warme zandtinten en tijdloze bescheiden silhouetten." },
    { "type": "text", "id": "topic_one_label", "label": "Tab 1 label", "default": "Abaya" },
    { "type": "textarea", "id": "topic_one_text", "label": "Tab 1 tekst", "default": "Onze abaya's hebben een verzorgde pasvorm, rustige lijnen en zijn geschikt voor dagelijks gebruik." },
    { "type": "url", "id": "topic_one_link", "label": "Tab 1 link" },
    { "type": "text", "id": "topic_two_label", "label": "Tab 2 label", "default": "Hijab" },
    { "type": "textarea", "id": "topic_two_text", "label": "Tab 2 tekst", "default": "Hijabs met comfortabele stofkwaliteit en neutrale kleuren die eenvoudig te combineren zijn." },
    { "type": "url", "id": "topic_two_link", "label": "Tab 2 link" },
    { "type": "text", "id": "topic_three_label", "label": "Tab 3 label", "default": "Stof" },
    { "type": "textarea", "id": "topic_three_text", "label": "Tab 3 tekst", "default": "Ademende materialen met nette afwerking, geselecteerd op draagcomfort en duurzaamheid." },
    { "type": "url", "id": "topic_three_link", "label": "Tab 3 link" },
    { "type": "text", "id": "topic_cta_label", "label": "Tab CTA label", "default": "Bekijk meer" },
    { "type": "text", "id": "meta_one", "label": "Meta 1", "default": "Ademend" },
    { "type": "text", "id": "meta_two", "label": "Meta 2", "default": "Maxi" },
    { "type": "text", "id": "meta_three", "label": "Meta 3", "default": "Regular fit" },
    { "type": "color", "id": "bg_start", "label": "Background start", "default": "#f9f4eb" },
    { "type": "color", "id": "bg_end", "label": "Background end", "default": "#efe5d5" },
    { "type": "color", "id": "accent", "label": "Accent", "default": "#a7834e" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2b241d" }
  ],
  "presets": [{ "name": "DIQA Waterfall Hero" }]
}
{% endschema %}
