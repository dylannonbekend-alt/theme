{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ section.settings.heading }}</h2>
      <p class="diqa-copy">{{ section.settings.copy }}</p>

      <div class="diqa-grid-3">
        {% for block in section.blocks %}
          <article class="diqa-pill" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MarOumayra Collection Intro",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The wardrobe, elevated."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Text",
      "default": "Curated categories designed with clean silhouettes, premium materials, and a calm modern identity."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Abayas"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Fluid cuts with a polished finish. Made to move with grace."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "MarOumayra Collection Intro"
    }
  ]
}
{% endschema %}
