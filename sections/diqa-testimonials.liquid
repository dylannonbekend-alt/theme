{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ section.settings.heading }}</h2>
      <p class="diqa-copy">{{ section.settings.copy }}</p>

      <div class="diqa-quotes">
        {% for block in section.blocks %}
          <blockquote class="diqa-quote" {{ block.shopify_attributes }}>
            <p>"{{ block.settings.quote }}"</p>
            <strong>{{ block.settings.author }}</strong>
          </blockquote>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MarOumayra Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Klantervaring"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beoordeeld op kwaliteit en pasvorm"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Text",
      "default": "Echte feedback van klanten die kiezen voor kwaliteit en stijl."
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review",
          "default": "De afwerking en kwaliteit zijn netjes en consistent."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Naam",
          "default": "Amina - Amsterdam"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "MarOumayra Testimonials",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote": "De afwerking en kwaliteit zijn netjes en consistent.",
            "author": "Amina - Amsterdam"
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote": "Mooie pasvorm en snelle levering. Product komt overeen met de foto's.",
            "author": "Youssef - Rotterdam"
          }
        }
      ]
    }
  ]
}
{% endschema %}
