{{ 'diqa-luxury-sections.css' | asset_url | stylesheet_tag }}

<section class="diqa-section">
  <div class="page-width">
    <div class="diqa-surface">
      <p class="diqa-kicker">{{ section.settings.kicker }}</p>
      <h2 class="diqa-heading">{{ section.settings.heading }}</h2>
      <p class="diqa-copy">{{ section.settings.copy }}</p>

      <div class="diqa-grid-3">
        {% for block in section.blocks %}
          <article class="diqa-pill" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.copy }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MarOumayra Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Merkverhaal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Duidelijke stijl en sterke identiteit"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Text",
      "default": "MarOumayra combineert kwaliteitsmaterialen, tijdloze silhouetten en nette afwerking voor dagelijks gebruik."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pijler",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Kwaliteitsmaterialen"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Tekst",
          "default": "Zorgvuldig geselecteerde materialen en afwerking met focus op draagcomfort."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "MarOumayra Brand Story",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Kwaliteitsmaterialen",
            "copy": "Zorgvuldig geselecteerde materialen en afwerking met focus op draagcomfort."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Minimalistische stijl",
            "copy": "Ontwerp gericht op eenvoud, balans en een verzorgde uitstraling."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Gerichte collecties",
            "copy": "Selecte releases en duidelijke collectielijnen voor een herkenbare merkbeleving."
          }
        }
      ]
    }
  ]
}
{% endschema %}
